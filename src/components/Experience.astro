---
const experiences = [
  {
    period: "AGO 2025 — ACTUALIDAD",
    role: "Soporte y Desarrollo Web Freelance",
    company: "Sandoval S.A. – Serviteca",
    details: [
      "Implementé y brindé soporte técnico a un sistema web integral para la gestión de clientes y seguimiento de servicios automotrices.",
      "Atendí continuamente los requerimientos técnicos del cliente, asegurando la correcta adopción y funcionamiento del sistema.",
      "Logré un 40% de mejora en el orden operativo gracias a la digitalización y centralización de la información."
    ]
  },
  {
    period: "JUN 2025 — DIC 2025",
    role: "Administrador de Pañol Tecnologías de Información y Ciberseguridad",
    company: "INACAP Sede Chillán",
    details: [
      "Entregué soporte operativo y técnico directo a docentes, funcionarios y estudiantes en el uso de la infraestructura tecnológica.",
      "Realicé labores continuas de mantenimiento de hardware y organización de espacios de trabajo en talleres y laboratorios.",
      "Gestioné el control de inventario de equipos e insumos, tomando decisiones estratégicas en la reposición de materiales.",
      "Mejoré los tiempos de respuesta a solicitudes técnicas en un 30%, asegurando la continuidad operativa y contribuyendo a la ocupación completa de cupos en áreas tecnológicas.",
      "Me destaqué por mi alto nivel de responsabilidad, orden y capacidad de respuesta en entornos dinámicos."
    ]
  },
  {
    period: "NOV 2024 — JUN 2025",
    role: "Profesor de Informática y Telecomunicaciones",
    company: "Liceo Técnico INSUCO Chillán",
    details: [
      "Lideré un proyecto técnico para mejorar la infraestructura de red del establecimiento mediante la instalación de dispositivos Ubiquiti, optimizando el rendimiento y disponibilidad en un 90% para más de 3.000 conexiones simultáneas.",
      "Brindé orientación técnica y facilitación efectiva a estudiantes en el uso de laboratorios de informática.",
      "Diseñé material pedagógico y guías de laboratorio enfocadas en redes, hardware y programación."
    ]
  }
];
---

<section class="mb-section-gap" id="experience">
  <div class="hairline mb-12"></div>
  <h2 class="font-headline-md text-headline-md mb-16 italic">Trayectoria Profesional</h2>
  <div class="space-y-24">
    {experiences.map((exp, index) => (
      <div>
        <div class="grid grid-cols-1 md:grid-cols-12 gap-gutter group">
          <div class="md:col-span-3">
            <span class="font-label-caps text-label-caps text-secondary block mb-2">{exp.period}</span>
            <h3 class="font-headline-sm text-headline-sm">{exp.role}</h3>
            {exp.company && (
              <p class="font-label-caps text-label-caps text-on-primary-container mt-1">
                {exp.company}
              </p>
            )}
          </div>
          <div class="md:col-span-9">
            {exp.details ? (
              <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                {exp.details.map(detail => (
                  <p class="font-body-md text-body-md text-secondary">{detail}</p>
                ))}
              </div>
            ) : (
              <p class="font-body-md text-body-md text-secondary">{exp.description}</p>
            )}
          </div>
        </div>
        {index < experiences.length - 1 && <div class="hairline opacity-30 mt-24"></div>}
      </div>
    ))}
  </div>
</section>
