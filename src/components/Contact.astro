---

<section class="mb-section-gap text-center flex flex-col items-center" id="contact">
  <div class="hairline mb-16"></div>
  
  <!-- Subtitle -->
  <span class="font-label-caps text-label-caps text-secondary uppercase tracking-widest mb-4 block">
    ¿Qué sigue?
  </span>

  <!-- Title in EB Garamond -->
  <h2 class="font-display-lg text-display-lg-mobile md:text-display-lg mb-8 italic text-primary">
    Hablemos
  </h2>

  <!-- Description -->
  <p class="font-body-lg text-body-lg text-secondary leading-relaxed mb-12 max-w-2xl mx-auto">
    Actualmente estoy disponible para nuevos proyectos o roles desafiantes en ingeniería de software. Si tienes una idea o quieres saludar, ¡mis bandejas de entrada están abiertas!
  </p>

  <!-- Button in Paper & Ink Style -->
  <a 
    href="mailto:rodrigo.sandoval.dev@gmail.com" 
    class="btn-pill"
  >
    Enviar Mensaje
  </a>

  <!-- Social Icons matching the rest of the style -->
  <div class="flex gap-8 mt-16 justify-center">
    <a 
      href="https://www.linkedin.com/in/rodrigo-sandoval-briones/" 
      target="_blank"
      rel="noopener noreferrer"
      aria-label="LinkedIn"
      class="text-secondary hover:text-primary transition-colors duration-300"
    >
      <span class="devicon-linkedin-plain text-2xl"></span>
    </a>
    <a 
      href="https://github.com/TATAPIERCE-dev" 
      target="_blank"
      rel="noopener noreferrer"
      aria-label="GitHub"
      class="text-secondary hover:text-primary transition-colors duration-300"
    >
      <span class="devicon-github-original text-2xl"></span>
    </a>
  </div>
</section>
