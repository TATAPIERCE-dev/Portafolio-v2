<nav class="fixed top-0 w-full z-50 flex justify-between items-center px-margin-mobile md:px-margin-desktop py-gutter bg-background/80 backdrop-blur-sm border-b border-outline-variant transition-shadow duration-300">
  <div class="font-headline-sm text-headline-sm text-primary uppercase tracking-tighter">
    Rodrigo Sandoval
  </div>
  
  <div class="flex gap-6 items-center">
    <!-- Desktop Nav Links -->
    <div class="hidden md:flex gap-8 items-center">
      <a class="font-sans text-sm font-semibold tracking-widest text-primary border-b border-primary pb-1 hover:text-primary transition-colors duration-300 nav-link" href="#hero">INICIO</a>
      <a class="font-sans text-sm font-semibold tracking-widest text-secondary hover:text-primary transition-colors duration-300 nav-link" href="#stack">SKILLS</a>
      <a class="font-sans text-sm font-semibold tracking-widest text-secondary hover:text-primary transition-colors duration-300 nav-link" href="#experience">TRAYECTORIA</a>
      <a class="font-sans text-sm font-semibold tracking-widest text-secondary hover:text-primary transition-colors duration-300 nav-link" href="#projects">PROYECTOS</a>
      <a class="font-sans text-sm font-semibold tracking-widest text-secondary hover:text-primary transition-colors duration-300 nav-link" href="#contact">CONTACTO</a>
    </div>

    <!-- Theme Toggle -->
    <button id="theme-toggle" class="p-2 text-primary focus:outline-none flex items-center justify-center hover:scale-110 transition-transform duration-200" aria-label="Cambiar tema">
      <span id="theme-icon-light" class="material-symbols-outlined text-xl hidden">light_mode</span>
      <span id="theme-icon-dark" class="material-symbols-outlined text-xl">dark_mode</span>
    </button>

    <!-- Mobile Menu Button -->
    <button id="menu-btn" class="md:hidden p-2 text-primary focus:outline-none" aria-label="Abrir menú">
      <span class="material-symbols-outlined text-2xl">menu</span>
    </button>
  </div>
</nav>

<!-- Mobile Menu Overlay -->
<div id="mobile-menu" class="fixed inset-0 bg-background/98 z-50 transform translate-x-full transition-transform duration-300 ease-in-out flex flex-col justify-center items-center gap-8 md:hidden">
  <button id="close-btn" class="absolute top-8 right-margin-mobile p-2 text-primary focus:outline-none" aria-label="Cerrar menú">
    <span class="material-symbols-outlined text-3xl">close</span>
  </button>
  <a class="font-headline-md text-headline-md text-primary hover:text-secondary py-2 mobile-nav-link" href="#hero">INICIO</a>
  <a class="font-headline-md text-headline-md text-secondary hover:text-primary py-2 mobile-nav-link" href="#stack">SKILLS</a>
  <a class="font-headline-md text-headline-md text-secondary hover:text-primary py-2 mobile-nav-link" href="#experience">TRAYECTORIA</a>
  <a class="font-headline-md text-headline-md text-secondary hover:text-primary py-2 mobile-nav-link" href="#projects">PROYECTOS</a>
  <a class="font-headline-md text-headline-md text-secondary hover:text-primary py-2 mobile-nav-link" href="#contact">CONTACTO</a>
</div>

<script>
  // Mobile menu open/close toggling
  const menuBtn = document.getElementById('menu-btn');
  const closeBtn = document.getElementById('close-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileLinks = document.querySelectorAll('.mobile-nav-link');

  const openMenu = () => {
    if (mobileMenu) {
      mobileMenu.classList.remove('translate-x-full');
      document.body.style.overflow = 'hidden'; // Prevent background scrolling
    }
  };

  const closeMenu = () => {
    if (mobileMenu) {
      mobileMenu.classList.add('translate-x-full');
      document.body.style.overflow = ''; // Restore scrolling
    }
  };

  menuBtn?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);

  // Custom Smooth Scrolling with custom duration/speed
  const easeInOutQuad = (t: number, b: number, c: number, d: number) => {
    t /= d / 2;
    if (t < 1) return (c / 2) * t * t + b;
    t--;
    return (-c / 2) * (t * (t - 2) - 1) + b;
  };

  const smoothScrollTo = (targetId: string, duration: number) => {
    const targetElement = document.getElementById(targetId);
    if (!targetElement) return;

    // 90px offset to clear the fixed top navbar
    const targetPosition = targetElement.getBoundingClientRect().top + window.pageYOffset - 90;
    const startPosition = window.pageYOffset;
    const distance = targetPosition - startPosition;
    let startTime: number | null = null;

    const animation = (currentTime: number) => {
      if (startTime === null) startTime = currentTime;
      const timeElapsed = currentTime - startTime;
      const run = easeInOutQuad(timeElapsed, startPosition, distance, duration);
      window.scrollTo(0, run);
      if (timeElapsed < duration) {
        requestAnimationFrame(animation);
      } else {
        window.scrollTo(0, targetPosition); // exact placement at the end
      }
    };

    requestAnimationFrame(animation);
  };

  const handleNavLinkClick = (e: Event) => {
    e.preventDefault();
    const href = (e.currentTarget as HTMLAnchorElement).getAttribute('href');
    if (href && href.startsWith('#')) {
      const targetId = href.substring(1);
      closeMenu();
      // Scroll to the target section over 800ms for a snappy yet smooth scroll
      smoothScrollTo(targetId, 800);
    }
  };

  const navLinks = document.querySelectorAll('.nav-link');
  navLinks.forEach(link => {
    link.addEventListener('click', handleNavLinkClick);
  });
  mobileLinks.forEach(link => {
    link.addEventListener('click', handleNavLinkClick);
  });

  // Theme Toggling Logic
  const themeToggle = document.getElementById('theme-toggle');
  const lightIcon = document.getElementById('theme-icon-light');
  const darkIcon = document.getElementById('theme-icon-dark');

  const updateThemeUI = () => {
    const isDark = document.documentElement.classList.contains('dark');
    if (isDark) {
      lightIcon?.classList.remove('hidden');
      darkIcon?.classList.add('hidden');
    } else {
      lightIcon?.classList.add('hidden');
      darkIcon?.classList.remove('hidden');
    }
  };

  // Initialize UI state
  updateThemeUI();

  themeToggle?.addEventListener('click', () => {
    const isCurrentlyDark = document.documentElement.classList.contains('dark');

    if (isCurrentlyDark) {
      const overlay = document.getElementById('flashbang-overlay');
      const grenade = document.getElementById('flashbang-grenade');
      if (overlay && grenade) {
        // Bloquear clicks e inicializar overlay transparente
        overlay.style.pointerEvents = 'auto';
        overlay.style.transition = 'none';
        overlay.style.backgroundColor = 'transparent';
        overlay.style.opacity = '1';

        // Mostrar la granada y activar la animación de rebote
        grenade.style.display = 'block';
        grenade.classList.remove('animate-grenade-bounce');
        void grenade.offsetWidth; // Reflujo para reiniciar animación
        grenade.classList.add('animate-grenade-bounce');

        // Reproducir el sonido 1 segundo antes de la explosión (a los 1.0s)
        setTimeout(() => {
          const audio = new Audio('/flashbang.mp3');
          audio.play().catch(err => {
            console.warn("Audio play blocked by browser policy:", err);
          });
        }, 1000);

        // A los 2 segundos (explosión visual y cambio de tema)
        setTimeout(() => {
          // Destello blanco y ocultar granada
          overlay.style.transition = 'none';
          overlay.style.backgroundColor = 'white';
          grenade.style.display = 'none';

          // Cambiar de tema al modo claro
          document.documentElement.classList.remove('dark');
          localStorage.setItem('theme', 'light');
          updateThemeUI();

          // Desvanecimiento gradual
          setTimeout(() => {
            overlay.style.transition = 'opacity 2.5s cubic-bezier(0.1, 0.8, 0.3, 1)';
            overlay.style.opacity = '0';
            overlay.style.pointerEvents = 'none'; // Desbloquear clicks
          }, 50);
        }, 2000);
      } else {
        // Fallback si los elementos no están disponibles
        document.documentElement.classList.remove('dark');
        localStorage.setItem('theme', 'light');
        updateThemeUI();
      }
    } else {
      // Transición inmediata a modo oscuro
      document.documentElement.classList.add('dark');
      localStorage.setItem('theme', 'dark');
      updateThemeUI();
    }
  });

  // Dynamic active link indicator based on scroll
  const sections = document.querySelectorAll('section[id]');

  const highlightNav = () => {
    let scrollY = window.pageYOffset;

    sections.forEach(current => {
      const sectionHeight = (current as HTMLElement).offsetHeight;
      const sectionTop = (current as HTMLElement).offsetTop - 150;
      const sectionId = current.getAttribute('id');

      if (scrollY > sectionTop && scrollY <= sectionTop + sectionHeight) {
        navLinks.forEach(link => {
          link.classList.remove('text-primary', 'border-b', 'border-primary', 'pb-1');
          link.classList.add('text-secondary');
          if (link.getAttribute('href') === `#${sectionId}`) {
            link.classList.add('text-primary', 'border-b', 'border-primary', 'pb-1');
            link.classList.remove('text-secondary');
          }
        });
      }
    });
  };

  window.addEventListener('scroll', highlightNav);

  // Scroll Shadow Effect
  const nav = document.querySelector('nav');
  window.addEventListener('scroll', () => {
    if (nav) {
      if (window.scrollY > 50) {
        nav.classList.add('shadow-sm');
      } else {
        nav.classList.remove('shadow-sm');
      }
    }
  });
</script>
