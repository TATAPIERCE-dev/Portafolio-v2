---
const skillCategories = [
  {
    title: "Frontend",
    skills: [
      { name: "React", icon: "devicon-react-plain" },
      { name: "Next.js", icon: "devicon-nextjs-plain" },
      { name: "Tailwind", icon: "devicon-tailwindcss-plain" },
      { name: "TypeScript", icon: "devicon-typescript-plain" },
      { name: "JavaScript", icon: "devicon-javascript-plain" },
      { name: "HTML5", icon: "devicon-html5-plain" },
      { name: "CSS3", icon: "devicon-css3-plain" }
    ]
  },
  {
    title: "Backend",
    skills: [
      { name: "Node", icon: "devicon-nodejs-plain" },
      { name: "Express", icon: "devicon-express-original" },
      { name: "NestJS", icon: "devicon-nestjs-original" },
      { name: "AdonisJS", icon: "devicon-adonisjs-original" }
    ]
  },
  {
    title: "Host",
    skills: [
      { name: "AWS", icon: "devicon-amazonwebservices-plain" },
      { name: "Vercel", icon: "devicon-vercel-line" },
      { name: "Netlify", icon: "devicon-netlify-plain" }
    ]
  },
  {
    title: "Database",
    skills: [
      { name: "PostgreSQL", icon: "devicon-postgresql-plain" },
      { name: "MongoDB", icon: "devicon-mongodb-plain" }
    ]
  },
  {
    title: "DevOps y Herramientas",
    skills: [
      { name: "Docker", icon: "devicon-docker-plain" },
      { name: "Git", icon: "devicon-git-plain" },
      { name: "GitHub", icon: "devicon-github-original" }
    ]
  }
];
---

<section class="mb-section-gap" id="stack">
  <div class="hairline mb-12"></div>
  <h2 class="font-headline-md text-headline-md mb-16 italic">Stack Principal</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-gutter">
    {skillCategories.map(category => (
      <div class="p-8 border border-outline-variant bg-background/40 backdrop-blur-[2px] hover:bg-surface-container hover:border-primary transition-all duration-300 group">
        <h4 class="font-label-caps text-label-caps text-primary mb-6 group-hover:translate-x-1 transition-transform duration-300">
          {category.title}
        </h4>
        <ul class="space-y-3 font-body-sm text-body-sm text-secondary">
          {category.skills.map(skill => (
            <li class="flex items-center gap-3 hover:text-primary transition-colors duration-200 group/item">
              <span class={`${skill.icon} colored text-lg group-hover/item:scale-110 transition-transform duration-200`}></span>
              <span>{skill.name}</span>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>
