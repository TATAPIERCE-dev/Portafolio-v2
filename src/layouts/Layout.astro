---
import '../styles/global.css';
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>Rodrigo Sandoval | Portfolio</title>
		<!-- Theme Initialization Script -->
		<script is:inline>
			const theme = (() => {
				if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
					return localStorage.getItem('theme');
				}
				return 'dark';
			})();
			
			if (theme === 'dark') {
				document.documentElement.classList.add('dark');
			} else {
				document.documentElement.classList.remove('dark');
			}
		</script>
		<!-- Google Fonts: EB Garamond for Serif, Inter for Sans -->
		<link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400..800;1,400..800&family=Inter:wght@300;400;600&display=swap" rel="stylesheet"/>
		<!-- Material Symbols -->
		<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
		<!-- Devicons -->
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css" />
	</head>
	<body class="font-body-md text-body-md">
		<slot />
		
		<!-- Flashbang Container -->
		<div id="flashbang-overlay" class="fixed inset-0 z-[9999] pointer-events-none bg-transparent flex items-center justify-center">
			<img id="flashbang-grenade" src="/flashbang.png" alt="Flashbang" class="hidden w-28 h-28 object-contain select-none pointer-events-none" />
		</div>

		<style is:global>
			@keyframes flashbang-bounce {
				0% {
					transform: translate(50vw, -100vh) rotate(0deg) scale(0.5);
					animation-timing-function: ease-in;
				}
				40% {
					transform: translate(10vw, 15vh) rotate(180deg) scale(1);
					animation-timing-function: ease-out;
				}
				55% {
					transform: translate(-5vw, -10vh) rotate(270deg) scale(1);
					animation-timing-function: ease-in;
				}
				70% {
					transform: translate(-10vw, 8vh) rotate(360deg) scale(1);
					animation-timing-function: ease-out;
				}
				85% {
					transform: translate(-12vw, -2vh) rotate(400deg) scale(1);
					animation-timing-function: ease-in;
				}
				100% {
					transform: translate(-13vw, 4vh) rotate(420deg) scale(1);
				}
			}

			.animate-grenade-bounce {
				display: block !important;
				animation: flashbang-bounce 2s forwards;
			}
		</style>
	</body>
</html>
